# Copy to `frontend/.deploy.secrets` and fill in. This file is gitignored.
# Used only during deploy; never committed.

# Your OSM account login (the Geofabrik internal server authenticates against OSM).
GEOFABRIK_USER=
GEOFABRIK_PASSWORD=

# R2 S3 API token for this Cloudflare account (Object Read & Write).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Optional: ARN of an existing GitHub Actions OIDC provider in this AWS account
# (check with: aws iam list-open-id-connect-providers). Leave empty to have the
# stack create one. The shared account may already have one.
GITHUB_OIDC_PROVIDER_ARN=
